aws_region = "us-east-1"

github_org = "my-org"

# Repos allowed to push — use "*" to allow the whole org
github_allowed_repos = [
  "service-a",
  "service-b",
]

repositories = {
  "shared/service-a" = {
    tagged_image_count   = 10
    scan_on_push         = true
    image_tag_mutability = "IMMUTABLE"
  }
  "shared/service-b" = {}   # uses all defaults
}

# Set to false if a GitHub OIDC provider already exists in this account
create_github_oidc_provider = true

tags = {
  Team      = "platform"
  ManagedBy = "terraform"
}
