# Terraform working directories and generated files
.terraform/
*.tfstate
*.tfstate.backup
tfplan.binary
crash.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Per-developer local variable overrides — copy from terraform.tfvars.example and edit
terraform/environments/core/terraform.tfvars

# Backend config files — generated per-developer by the bootstrap CLI, never committed
**/backend.hcl

# Bootstrap CLI state — written by `uv run scripts/bootstrap.py apply-core`
scripts/.bootstrap-state.json

# Secrets and credentials — never commit these
.env
.env.*
*.pem
*.key
*.p12
*.pfx

# macOS
.DS_Store

# Editor
.idea/
.vscode/
*.swp
